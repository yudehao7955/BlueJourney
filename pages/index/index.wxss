/* pages/index/index.wxss */
page {
  height: 100%;
  margin: 0;
  padding: 0;
  overflow: hidden;
}

.container {
  height: 100%;
  width: 100%;
  position: relative;
  background: #000;
  margin: 0;
  padding: 0;
}

/* 地图 */
.map {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

/* 顶部左侧用户卡片 */
.top-left-card {
  position: fixed;
  top: 80rpx;
  left: 30rpx;
  z-index: 100;
}

.user-card {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 20rpx 16rpx 16rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.avatar-btn {
  padding: 0;
  border: none;
  background: transparent;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

.user-text {
  margin-left: 12rpx;
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 18rpx;
  color: #666;
  line-height: 1;
}

.nickname {
  font-size: 26rpx;
  font-weight: bold;
  color: #1a1a1a;
  line-height: 1.2;
}

/* 顶部右侧天气卡片 */
.top-right-card {
  position: fixed;
  top: 80rpx;
  right: 30rpx;
  z-index: 100;
  display: flex;
  align-items: center;
  background: #fff;
  padding: 14rpx 24rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.weather-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.weather-temp {
  font-size: 24rpx;
  font-weight: 600;
  color: #0066cc;
}

/* 右侧悬浮工具栏 */
.right-tools {
  position: fixed;
  right: 30rpx;
  top: 280rpx;
  z-index: 100;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tool-btn {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.tool-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 当前位置标记 */
.location-marker {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 50;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.marker-pulse {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  background: rgba(0, 102, 204, 0.2);
  border-radius: 50%;
  animation: pulse 2s ease-out infinite;
}

@keyframes pulse {
  0% {
    transform: scale(0.5);
    opacity: 1;
  }
  100% {
    transform: scale(2);
    opacity: 0;
  }
}

.marker-dot {
  width: 24rpx;
  height: 24rpx;
  background: #0066cc;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 102, 204, 0.4);
}

/* 底部控制面板 */
.bottom-panel {
  position: fixed;
  bottom: 80rpx;
  left: 30rpx;
  right: 30rpx;
  z-index: 100;
}

.data-card {
  background: linear-gradient(135deg, #0066CC, #3385E6);
  border-radius: 48rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 102, 204, 0.25);
}

/* 数据展示区 */
.data-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.data-item {
  flex: 1;
  text-align: center;
}

.data-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.data-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  font-family: 'Inter', -apple-system, sans-serif;
}

.data-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 控制按钮区 */
.control-area {
  display: flex;
  justify-content: center;
}

.start-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  height: 112rpx;
  background: linear-gradient(135deg, #ff8c42, #ffa566);
  border-radius: 56rpx;
  border: none;
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  box-shadow: 0 12rpx 32rpx rgba(255, 140, 66, 0.35);
}

.start-btn::after {
  border: none;
}

.btn-icon {
  font-size: 40rpx;
}

.control-btns {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.pause-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 112rpx;
  background: #fff;
  border: 2rpx solid #999;
  border-radius: 56rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #666;
}

.pause-btn.active {
  border: 2rpx solid #0066cc;
  color: #0066cc;
}

.pause-btn::after {
  border: none;
}

.stop-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #ff4d4f, #ff6b6b);
  border-radius: 56rpx;
  border: none;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  box-shadow: 0 12rpx 32rpx rgba(255, 77, 79, 0.35);
}

.stop-btn::after {
  border: none;
}

/* 调试面板 */
.debug-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 35vh;
  background: rgba(0, 0, 0, 0.85);
  z-index: 9999;
  display: flex;
  flex-direction: column;
  transition: height 0.3s ease;
}

.debug-panel.collapsed {
  height: 40rpx;
}

.debug-panel.collapsed .debug-content {
  display: none;
}

.debug-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 16rpx;
  background: #222;
  border-bottom: 1rpx solid #444;
}

.debug-header text {
  font-size: 24rpx;
  color: #888;
}

.debug-btns {
  display: flex;
  gap: 20rpx;
}

.debug-btn {
  color: #4a90e2 !important;
  font-weight: bold;
}

.debug-content {
  flex: 1;
  overflow-y: scroll;
  padding: 8rpx;
}

.debug-line {
  font-size: 22rpx;
  color: #0f0;
  font-family: monospace;
  line-height: 1.4;
  word-break: break-all;
}