/* pages/team/team.wxss */
page {
  height: 100%;
  background: #f5f9fc;
}

.container {
  min-height: 100%;
  padding-bottom: 140rpx;
  position: relative;
}

/* 顶部渐变头部 */
.header-bg {
  background: linear-gradient(135deg, #0052A3, #0066CC);
  padding-top: calc(var(--status-bar-height) + 20rpx);
  padding-bottom: 60rpx;
  border-radius: 0 0 80rpx 80rpx;
  overflow: hidden;
}

.header-content {
  padding: 0 40rpx;
}

.main-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.sub-title {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* Tab切换 */
.tab-wrapper {
  display: flex;
  margin: -30rpx 30rpx 0;
  background: #fff;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  padding: 8rpx;
  position: relative;
  z-index: 10;
  padding-top: 50rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 44rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #fff;
  background: #0066CC;
  font-weight: bold;
}

/* 队伍列表 */
.team-list {
  padding: 30rpx 30rpx;
  height: 100%;
  box-sizing: border-box;
}

.team-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* 队伍信息 */
.team-info-card {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.team-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.team-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.creator {
  font-size: 26rpx;
  color: #666;
}

.member-count {
  font-size: 26rpx;
  color: #0066CC;
  background: rgba(0, 102, 204, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.team-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

/* 队员头像堆叠 */
.members-avatars {
  display: flex;
  align-items: center;
  padding: 8rpx 0 16rpx;
  margin-bottom: 16rpx;
}

/* 队长 - 显示完整信息 */
.leader-item {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar-lg {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
  border: 3rpx solid #0066CC;
}

.leader-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.leader-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.leader-role {
  font-size: 22rpx;
  color: #fff;
  background: #0066CC;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  width: fit-content;
}

/* 其他队员 - 只显示头像堆叠在右边 */
.other-avatars {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.avatar-sm {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-left: -16rpx;
  border: 2rpx solid #fff;
  background: #f0f0f0;
}

/* 操作按钮 */
.team-actions {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.action-btn {
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  text-align: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, #0066CC, #3385E6);
  color: #fff;
}

.action-btn.secondary {
  background: rgba(0, 102, 204, 0.1);
  color: #0066CC;
}

.action-btn.danger {
  background: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.action-btn.warning {
  background: rgba(255, 153, 0, 0.1);
  color: #ff9900;
}

.action-btn.invite {
  background: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 底部 创建按钮 */
.create-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx 40rpx;
  background: linear-gradient(180deg, transparent, #f5f9fc 60%);
  z-index: 100;
}

.create-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #0066CC, #3385E6);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(0, 102, 204, 0.25);
}

.create-btn::after {
  border: none;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 60vh;  /* 只占用最多60%屏幕高度，节省空间 */
}

.modal-content.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 40rpx;
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.input-textarea {
  width: 100%;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  gap: 16rpx;
}

.radio-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 16rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.radio-item.active {
  color: #0066CC;
  background: rgba(0, 102, 204, 0.1);
  border-color: #0066CC;
  font-weight: 500;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 0 40rpx 40rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
  border: none;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #0066CC, #3385E6);
  color: #fff;
  border: none;
}

.modal-btn::after {
  border: none;
}