.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.settings-list {
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.setting-label {
  font-size: 32rpx;
  color: #333333;
}

.setting-desc {
  padding: 20rpx 30rpx 30rpx;
  font-size: 28rpx;
  color: #999999;
  line-height: 1.5;
}
