/* pages/profile/profile.wxss */
page {
  height: 100%;
  background: #f5f9fc;
}

.container {
  min-height: 100%;
  position: relative;
}

/* 头部背景 */
.header-bg {
  height: 400rpx;
  background: linear-gradient(135deg, #003366, #0066cc);
  position: relative;
  border-radius: 0 0 80rpx 80rpx;
  overflow: hidden;
}

.wave-decoration {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNzAwIiBoZWlnaHQ9IjEwMCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cGF0aCBkPSJNMCAwaDY5OHYxMDBIMFYwem0wIDBoNjAwdjEwMEgwVjB6IiBmaWxsPSIjZmZmIiBmaWxsLW9wYWNpdHk9IjAuMSIvPjwvc3ZnPg==') no-repeat bottom;
  background-size: cover;
}

/* 用户信息区域 */
.profile-header {
  position: absolute;
  top: 160rpx;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  z-index: 10;
}

.avatar-wrapper {
  position: relative;
}

.avatar-btn {
  padding: 0;
  border: none;
  background: transparent;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: visible;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 8rpx solid #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.edit-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: #ff8c42;
  border-radius: 50%;
  border: 4rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 统计数据卡片 */
.stats-card {
  margin: -40rpx 40rpx 40rpx;
  background: #fff;
  border-radius: 48rpx;
  padding: 56rpx 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: space-between;
  position: relative;
  z-index: 20;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 0 8rpx;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1a1a1a;
  font-family: 'Inter', -apple-system, sans-serif;
  margin-bottom: 12rpx;
  line-height: 1.2;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.2;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: #e8e8e8;
  margin: 16rpx 0;
}

/* 功能列表 */
.menu-section {
  padding: 0 40rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  min-height: 100rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.menu-icon.bg-blue {
  background: rgba(0, 102, 204, 0.1);
}

.menu-icon.bg-orange {
  background: rgba(255, 140, 66, 0.1);
}

.menu-icon.bg-gray {
  background: rgba(102, 102, 102, 0.1);
}

.menu-icon.bg-green {
  background: rgba(82, 196, 26, 0.1);
}

.menu-icon.bg-red {
  background: rgba(255, 82, 82, 0.1);
}

.menu-icon-text {
  font-size: 36rpx;
}

.menu-content {
  flex: 1;
}

.menu-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 1.4;
}

.menu-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  line-height: 1.3;
}

.menu-arrow {
  font-size: 28rpx;
  color: #999;
}

/* 底部功能 */
.bottom-section {
  padding: 40rpx;
  padding-top: 0;
}